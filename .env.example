# ============================================
# ConstructionHub - Environment Variables
# ============================================
# Copy this file to .env and fill in real values for deployment.

# ── Database ──
DATABASE_URL=jdbc:postgresql://localhost:5432/constructionhub
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ── JWT ──
# Must be at least 256 bits (32+ characters). Generate with: openssl rand -base64 48
JWT_SECRET=

# ── Server ──
PORT=8080
SPRING_PROFILES_ACTIVE=production

# ── CORS ──
# Comma-separated origins allowed to call the API
CORS_ORIGINS=https://yourdomain.com

# ── Cloudflare R2 / S3 Storage (optional) ──
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=constructionhub-docs

# ── Frontend ──
VITE_API_URL=https://api.yourdomain.com
